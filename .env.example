# Copy to `.env` locally. For Cloudflare Pages, add keys per environment:
#   Preview / local QA  → VITE_APP_ENV=staging (or development), VITE_SOLANA_CLUSTER=devnet
#   Production (later)  → VITE_APP_ENV=production, VITE_SOLANA_CLUSTER=mainnet-beta + mainnet IDs
#
# Firebase: Firebase Console → Project settings → Your apps → Web app

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App environment: development | staging | production
# Build fails only when production + devnet (see vite-plugin-validate-production-env).
VITE_APP_ENV=development

# Solana cluster: devnet (default) | mainnet-beta | testnet
VITE_SOLANA_CLUSTER=devnet

# Dedicated devnet RPC (strongly recommended — avoids 429 on public api.devnet.solana.com)
# Example: https://devnet.helius-rpc.com/?api-key=YOUR_KEY
VITE_SOLANA_RPC_ENDPOINT=

# On-chain addresses (optional — devnet defaults match current Playground deployment)
VITE_USDFG_PROGRAM_ID=
VITE_USDFG_MINT=
VITE_USDFG_ADMIN_WALLET=
VITE_USDFG_PLATFORM_WALLET=

# Canonical origin for Open Graph / share URLs
VITE_SITE_ORIGIN=https://usdfg.pro
