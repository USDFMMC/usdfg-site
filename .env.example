# Copy to `.env` locally. For Cloudflare Pages, add the same keys in
# Project → Settings → Environment variables (Production / Preview as needed).
#
# Source: Firebase Console → Project settings → General → Your apps → Web app
# Use the full `firebaseConfig` / `firebase` object values (not Android/iOS keys).
#
# If you see auth/api-key-not-valid on usdfg.pro: set these in Cloudflare (then
# redeploy), AND in Google Cloud → Credentials → Browser key → HTTP referrers
# allow https://usdfg.pro/*

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Helius devnet (free tier): https://dashboard.helius.dev → API Keys → Devnet
# VITE_SOLANA_RPC_ENDPOINT=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
VITE_SOLANA_RPC_ENDPOINT=

# Canonical origin for Open Graph / share URLs (default: https://usdfg.pro)
VITE_SITE_ORIGIN=https://usdfg.pro

# Cloudflare Access (scripts/setup-cloudflare-access.mjs — not Vite build vars)
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_PAGES_PROJECT=usdfg-app
# CLOUDFLARE_ACCESS_ALLOWED_EMAILS=qa@example.com,founder@usdfg.pro

# TEMPORARY pre-launch /app gate (client-side; remove when Cloudflare Access is active)
# Optional override — defaults to 6837 in code if unset.
# VITE_ARENA_ACCESS_PASSWORD=6837
