# Copy to `.env` locally. For Cloudflare Pages, add the same keys in
# Project → Settings → Environment variables (Production / Preview as needed).
#
# Source: Firebase Console → Project settings → General → Your apps → Web app
# Use the full `firebaseConfig` / `firebase` object values (not Android/iOS keys).
#
# If you see auth/api-key-not-valid on usdfg.pro: set these in Cloudflare (then
# redeploy), AND in Google Cloud → Credentials → Browser key → HTTP referrers
# allow https://usdfg.pro/*

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_SOLANA_RPC_ENDPOINT=
