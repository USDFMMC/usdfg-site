rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Canonical user
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Wallet index
    match /usersByWallet/{wallet} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usersByWallet/$(wallet));

      allow update, delete: if false;
    }

    // Temporary read access for dev
    match /{document=**} {
      allow read: if true;
    }
  }
}
