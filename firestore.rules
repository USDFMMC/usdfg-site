rules_version = '2';

// =============================================================================
// Aligned with original USDFG architecture (usdfg-site style)
// -----------------------------------------------------------------------------
// - Every read/write requires Firebase Authentication (request.auth != null).
//   Anonymous sign-in counts as authenticated; unauthenticated clients cannot access data.
// - We do NOT enforce Solana wallet identity or challenge participant logic here.
//   Challenge integrity, payouts, and admin actions on escrow rely on client checks +
//   on-chain programs (e.g. resolveAdminChallengeOnChain). ADMIN_WALLET gating stays in app code.
// - DisputeConsole: Firebase email users listed in `admins/{uid}` use isAdmin() for audit log.
// - Chat: immutable (no update/delete) to avoid accidental destructive patterns; creates require auth + schema keys.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Firebase admin (DisputeConsole): document at admins/{firebaseUid} with active !== false (checked in app).
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // --------------------------------------------------------------------------
    // challenges — auth only; no wallet / participant rules in Firestore
    // --------------------------------------------------------------------------
    match /challenges/{challengeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // challenge_chats — auth to read/write messages; documents immutable (no update/delete)
    // --------------------------------------------------------------------------
    match /challenge_chats/{chatId} {
      allow get, list: if isSignedIn();

      allow create: if isSignedIn() &&
        request.resource.data.keys().hasAll(['challengeId', 'text', 'sender', 'timestamp']);

      allow update, delete: if false;
    }

    // --------------------------------------------------------------------------
    // voice_signals
    // --------------------------------------------------------------------------
    match /voice_signals/{signalId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // tournament_disputes
    // --------------------------------------------------------------------------
    match /tournament_disputes/{disputeId} {
      allow get, list: if request.auth != null;
      allow create: if request.auth != null;

      // Allow authenticated updates so client-side tournament dispute resolution works.
      // This matches the current hybrid architecture where Firestore is a state/UI layer,
      // while security/authority is enforced by app logic and on-chain rules.
      allow update: if request.auth != null;

      allow delete: if false;
    }

    // --------------------------------------------------------------------------
    // player_stats — auth only (doc id is wallet string; not validated in rules)
    // --------------------------------------------------------------------------
    match /player_stats/{wallet} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // challenges_archive
    // --------------------------------------------------------------------------
    match /challenges_archive/{challengeId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // users
    // --------------------------------------------------------------------------
    match /users/{userId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // lock_notifications
    // --------------------------------------------------------------------------
    match /lock_notifications/{notificationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // challenge_notifications
    // --------------------------------------------------------------------------
    match /challenge_notifications/{notificationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // friendly_matches
    // --------------------------------------------------------------------------
    match /friendly_matches/{matchId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // free_claims
    // --------------------------------------------------------------------------
    match /free_claims/{claimId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // founder_rewards
    // --------------------------------------------------------------------------
    match /founder_rewards/{rewardId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isSignedIn();
      allow update: if false;
    }

    // --------------------------------------------------------------------------
    // stats
    // --------------------------------------------------------------------------
    match /stats/{statId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // trust_reviews
    // --------------------------------------------------------------------------
    match /trust_reviews/{reviewId} {
      allow get, list: if isSignedIn();
      allow create, delete: if isSignedIn();
      allow update: if false;
    }

    // --------------------------------------------------------------------------
    // teams
    // --------------------------------------------------------------------------
    match /teams/{teamId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // --------------------------------------------------------------------------
    // challenge_lobbies
    // --------------------------------------------------------------------------
    match /challenge_lobbies/{challengeId} {
      match /spectators/{wallet} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /voice_controls/{wallet} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /mic_requests/{wallet} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /voice_state/{docId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }

      match /stats/{statId} {
        allow get, list: if isSignedIn();
        allow create, update, delete: if isSignedIn();
      }
    }

    // --------------------------------------------------------------------------
    // admins — client read only if caller has an admins profile; no client writes
    // --------------------------------------------------------------------------
    match /admins/{adminId} {
      allow read: if isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      allow write: if false;
    }

    // --------------------------------------------------------------------------
    // admin_audit_log — DisputeConsole (Firebase admins only)
    // --------------------------------------------------------------------------
    match /admin_audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }
  }
}
