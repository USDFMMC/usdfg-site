rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    /** Wave 1A+ — forbid privileged/admin/payout terminal fields on client create. */
    function challengeCreatePrivilegedFieldsAbsent() {
      return !('winner' in request.resource.data)
        && !('needsPayout' in request.resource.data)
        && !('canClaim' in request.resource.data)
        && !('payoutStatus' in request.resource.data)
        && !('payoutLockOwner' in request.resource.data)
        && !('payoutTriggered' in request.resource.data)
        && !('prizeClaimedAt' in request.resource.data)
        && !('payoutSignature' in request.resource.data)
        && !('resolvedBy' in request.resource.data)
        && !('resolvedAt' in request.resource.data)
        && !('adminResolutionTx' in request.resource.data)
        && !('statsApplied' in request.resource.data);
    }

    function challengeCreateSafeDefaultsOk() {
      return request.resource.data.status == "pending_waiting_for_opponent"
        // New challenges must not carry results or dispute markers.
        && !('results' in request.resource.data)
        && !('disputedBy' in request.resource.data)
        && !('disputedAt' in request.resource.data)
        && !('disputeReason' in request.resource.data)
        // On-chain identity is established only after funding; PDA must be absent/null at creation.
        && (!('pda' in request.resource.data) || request.resource.data.pda == null);
    }

    function challengeCreateIdentityOk() {
      return request.resource.data.createdByUid == request.auth.uid
        // Creator wallet must be present and mirrored in players[0] for 1v1 (and matches existing create flow).
        && request.resource.data.creator is string
        && request.resource.data.creator.size() > 0
        && request.resource.data.players is list
        && request.resource.data.players.size() >= 1
        && request.resource.data.players[0] == request.resource.data.creator;
    }

    /** Active admin doc at admins/{auth.uid} (used by client isAdmin / dispute console). */
    function isAdminUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active != false;
    }

    /** Do not allow changing creator UID once set (UID-only integrity). */
    function challengeCreatedByUidUnchanged() {
      return !('createdByUid' in resource.data)
        || request.resource.data.createdByUid == resource.data.createdByUid;
    }

    /** UID-only: creator or known opponent on the stored document. */
    function isChallengeParticipant() {
      return isSignedIn()
        && (
          resource.data.createdByUid == request.auth.uid
          || resource.data.opponentUid == request.auth.uid
        );
    }

    /** Tournament / multi-slot: already listed as a participant UID. */
    function isListedInPlayersUid() {
      return isSignedIn()
        && resource.data.playersUid is list
        && request.auth.uid in resource.data.playersUid;
    }

    /**
     * First opponent bind: writeChallengeFields sets opponentUid in the same update as join intent
     * (resource.opponentUid was unset; createdByUid unchanged).
     */
    function isOpponentUidFirstBind() {
      return isSignedIn()
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.auth.uid != resource.data.createdByUid
        && (!('opponentUid' in resource.data) || resource.data.opponentUid == null)
        && request.resource.data.opponentUid == request.auth.uid;
    }

    /** On-chain PDA: set once; never change (escrow identity lock). */
    function challengePdaImmutableAfterSet() {
      return resource.data.pda == null
        || request.resource.data.pda == resource.data.pda;
    }

    /** Payout tx id: set once; never change (idempotency / no double-claim swap). */
    function challengePayoutSignatureImmutable() {
      return request.resource.data.payoutSignature == resource.data.payoutSignature
        || resource.data.payoutSignature == null;
    }

    function isJoinIntentUpdate() {
      return isSignedIn()
        && resource.data.status == "pending_waiting_for_opponent"
        && request.resource.data.status == "creator_confirmation_required"
        && request.resource.data.pendingJoiner != null
        && request.resource.data.opponentWallet == request.resource.data.pendingJoiner
        && request.resource.data.pendingJoiner != resource.data.creatorWallet
        && resource.data.pendingJoiner == null
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'pendingJoiner',
          'opponentWallet',
          'creatorFundingDeadline',
          'updatedAt',
          'opponentUid'
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['opponentUid'])
          || request.resource.data.opponentUid == request.auth.uid
        );
    }

    /**
     * Wave 1B (minimal slice for launch): restrict client-driven status transitions
     * to the known 1v1 lifecycle so participants cannot self-complete from pending states.
     *
     * NOTE: This only constrains status changes. Non-status field writes are still governed
     * by privileged-field gates and other helpers.
     */
    function challengeStatusTransitionOk() {
      return (
        // No change — ok.
        request.resource.data.status == resource.data.status
        // Join intent (also checked by isJoinIntentUpdate()).
        || (
          resource.data.status == "pending_waiting_for_opponent"
          && request.resource.data.status == "creator_confirmation_required"
        )
        // Creator funds.
        || (
          resource.data.status == "creator_confirmation_required"
          && request.resource.data.status == "creator_funded"
        )
        // Joiner funds (paid challenges must have PDA).
        || (
          resource.data.status == "creator_funded"
          && request.resource.data.status == "active"
          && request.resource.data.pda != null
        )
        // Loss report.
        || (
          (resource.data.status == "active" || resource.data.status == "in-progress")
          && request.resource.data.status == "awaiting_auto_resolution"
        )
        // Clear provisional window.
        || (
          resource.data.status == "awaiting_auto_resolution"
          && request.resource.data.status == "active"
        )
        // Escalate dispute within window.
        || (
          resource.data.status == "awaiting_auto_resolution"
          && request.resource.data.status == "disputed"
        )
      );
    }

    function challengeUpdateDiff() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    /** Wave 1A — never client-writable except via Admin SDK / Cloud Functions. */
    function challengeAdminOnlyFieldsUntouched() {
      return !challengeUpdateDiff().hasAny([
        'resolvedBy',
        'resolvedAt',
        'adminResolutionTx',
        'statsApplied'
      ]);
    }

    function isValidWinnerAssignmentInUpdate() {
      return !('winner' in challengeUpdateDiff())
        || request.resource.data.winner == null
        || request.resource.data.winner == 'forfeit'
        || request.resource.data.winner == 'tie'
        || request.resource.data.winner == 'cancelled'
        || (
          request.resource.data.players is list
          && request.resource.data.winner in request.resource.data.players
        );
    }

    /**
     * Match resolution writes from participants (results, loss auto-window, dispute open, completion payout enablement).
     * Wave 1B will replace this with stricter per-transition allowlists.
     */
    function isParticipantGameplayResolutionUpdate() {
      return (isChallengeParticipant() || isListedInPlayersUid())
        && challengeAdminOnlyFieldsUntouched()
        && !challengeUpdateDiff().hasAny(['payoutLockOwner', 'payoutTriggered', 'prizeClaimedAt'])
        && isValidWinnerAssignmentInUpdate()
        // Prevent self-complete/resolve from pending/funding states.
        && (
          resource.data.status == 'active'
          || resource.data.status == 'in-progress'
          || resource.data.status == 'awaiting_auto_resolution'
        )
        && (
          request.resource.data.status == 'awaiting_auto_resolution'
          || (request.resource.data.status == 'disputed' && request.resource.data.winner == null)
          || request.resource.data.status == 'completed'
        );
    }

    /** Winner claim lock + post-chain payout fields (completed + needsPayout). */
    function isParticipantPayoutClaimUpdate() {
      let d = challengeUpdateDiff();
      return (isChallengeParticipant() || isListedInPlayersUid())
        && resource.data.status == 'completed'
        && (resource.data.needsPayout == true || resource.data.payoutStatus == 'processing')
        && challengeAdminOnlyFieldsUntouched()
        && !d.hasAny([
          'winner',
          'resolvedBy',
          'resolvedAt',
          'adminResolutionTx',
          'statsApplied',
          'canClaim',
          'status',
          'results',
          'players',
          'playersUid',
          'createdByUid',
          'opponentUid',
          'pda',
          'entryFee'
        ])
        && d.hasAny([
          'payoutStatus',
          'payoutLockOwner',
          'payoutAttemptedAt',
          'payoutSignature',
          'payoutTriggered',
          'prizeClaimedAt',
          'needsPayout'
        ])
        && (!('needsPayout' in d) || request.resource.data.needsPayout == false)
        // Never allow marking paid without a non-empty signature (or explicit already-processed sentinel).
        && (
          request.resource.data.payoutStatus != 'paid'
          || (
            request.resource.data.payoutTriggered == true
            && request.resource.data.payoutSignature is string
            && request.resource.data.payoutSignature.size() > 0
          )
        );
    }

    /**
     * Wave 1A — block forging privileged payout/admin fields; preserve gameplay + claim paths above.
     */
    function challengePrivilegedFieldsOk() {
      return isAdminUser()
        || isParticipantPayoutClaimUpdate()
        || isParticipantGameplayResolutionUpdate()
        || !challengeUpdateDiff().hasAny([
          'winner',
          'payoutStatus',
          'payoutLockOwner',
          'needsPayout',
          'canClaim',
          'payoutTriggered',
          'prizeClaimedAt',
          'resolvedBy',
          'resolvedAt',
          'adminResolutionTx',
          'statsApplied'
        ]);
    }

    // Canonical user
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Wallet index
    match /usersByWallet/{wallet} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/usersByWallet/$(wallet));

      allow update, delete: if false;
    }

    // User lock state (keyed by walletAddress; identity checked via usersByWallet index)
    match /user_locks/{wallet} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && exists(/databases/$(database)/documents/usersByWallet/$(wallet))
        && get(/databases/$(database)/documents/usersByWallet/$(wallet)).data.uid == request.auth.uid;
    }

    // challenges — gameplay (UID-only; no wallet checks in rules)
    match /challenges/{challengeId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && challengeCreateIdentityOk()
        && challengeCreateSafeDefaultsOk()
        && challengeCreatePrivilegedFieldsAbsent();

      allow update: if isSignedIn()
        && (
          isChallengeParticipant()
          || isListedInPlayersUid()
          || isOpponentUidFirstBind()
          || isJoinIntentUpdate()
          // Dispute console: admin may update while challenge is disputed (resolveAdminChallenge).
          || (isAdminUser() && resource.data.status == 'disputed')
        )
        && challengePdaImmutableAfterSet()
        && challengePayoutSignatureImmutable()
        && challengePrivilegedFieldsOk()
        && (
          // Admin path may override status transitions while disputed.
          (isAdminUser() && resource.data.status == 'disputed')
          || isJoinIntentUpdate()
          || challengeStatusTransitionOk()
        );

      // Client deletes disabled; use Admin SDK / scheduled functions if cleanup is required.
      allow delete: if false;
    }

    // challenge chat messages
    match /challenge_chats/{chatId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // voice signaling
    match /voice_signals/{signalId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // tournament disputes
    match /tournament_disputes/{disputeId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
    }

    // player stats — client writes disabled; updates via Admin SDK (functions) only
    match /player_stats/{wallet} {
      allow read: if true;
      allow write: if false;
    }

    // lock notifications (friendly match request/accept/cancel)
    match /lock_notifications/{matchId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
    }

    // challenge notifications
    match /challenge_notifications/{notificationId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
    }

    // teams
    match /teams/{teamId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // trust reviews
    match /trust_reviews/{reviewId} {
      allow read, create, delete: if isSignedIn();
      allow update: if false;
    }

    // founder rewards
    match /founder_rewards/{rewardId} {
      allow read, create, delete: if isSignedIn();
      allow update: if false;
    }

    // friendly matches
    match /friendly_matches/{matchId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // free claims
    match /free_claims/{claimId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // misc stats
    match /stats/{statId} {
      allow read, create, update, delete: if isSignedIn();
    }

    // Ephemeral submission audit (enable TTL on expiresAt in Firebase console)
    match /challenge_submissions/{docId} {
      allow create: if isSignedIn();
      allow read: if false;
      allow update, delete: if false;
    }

    // Admin dispute resolution audit (client DisputeConsole; Cloud Functions use Admin SDK)
    match /admin_audit_log/{docId} {
      allow create: if isAdminUser();
      allow read: if false;
      allow update, delete: if false;
    }

    // challenge lobbies + subcollections
    match /challenge_lobbies/{challengeId} {
      allow read, create, update, delete: if isSignedIn();

      match /{subcollection=**}/{docId} {
        allow read, create, update, delete: if isSignedIn();
      }
    }
  }
}
